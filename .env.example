# === CHAIN ===
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_BASE_RPC=https://sepolia.base.org
NEXT_PUBLIC_PARENT_DOMAIN=twinpilot.eth
# ENS resolves on Sepolia. Switch back to "mainnet" only if you provision a MAINNET_RPC.
NEXT_PUBLIC_ENS_NETWORK=sepolia
# Alchemy URL for Ethereum Sepolia, e.g. https://eth-sepolia.g.alchemy.com/v2/<KEY>
SEPOLIA_RPC=

# === PRIVY ===
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Public key from Privy Dashboard → Settings → API Keys (used to verify auth tokens server-side)
PRIVY_VERIFICATION_KEY=

# === LLM ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === APIFY ===
APIFY_API_KEY=
APIFY_X402_ENDPOINT=https://api.apify.com/v2/acts/{actor}/run-sync-get-dataset-items

# === ORBITPORT cTRNG ===
ORBITPORT_API_URL=https://api.orbitport.spacecomputer.io/v1
ORBITPORT_API_KEY=

# === NAMESTONE ===
NAMESTONE_API_KEY=

# === x402 sender (server-side; usually client uses Privy Smart Wallet) ===
X402_SENDER_KEY=

# === DEPLOYMENT ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
