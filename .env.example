# === CHAIN ===
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_BASE_RPC=https://sepolia.base.org
NEXT_PUBLIC_PARENT_DOMAIN=ethtwin.eth
# ENS resolves on Sepolia. Switch back to "mainnet" only if you provision a MAINNET_RPC.
NEXT_PUBLIC_ENS_NETWORK=sepolia
# Alchemy URL for Ethereum Sepolia, e.g. https://eth-sepolia.g.alchemy.com/v2/<KEY>
SEPOLIA_RPC=

# === PRIVY ===
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Public key from Privy Dashboard → Settings → API Keys (used to verify auth tokens server-side)
PRIVY_VERIFICATION_KEY=

# === LLM ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === APIFY ===
APIFY_API_KEY=
APIFY_X402_ENDPOINT=https://api.apify.com/v2/acts/{actor}/run-sync-get-dataset-items

# === ORBITPORT cTRNG ===
ORBITPORT_API_URL=https://api.orbitport.spacecomputer.io/v1
ORBITPORT_API_KEY=

# === SPACECOMPUTER ORBITPORT KMS (REQUIRED for KMS-managed twin keys) ===
# OAuth2 client credentials from https://docs.spacecomputer.io/docs/how-to/kms.
# Without these, /api/onboarding fails — every twin needs a real KMS key.
ORBITPORT_CLIENT_ID=
ORBITPORT_CLIENT_SECRET=

# === SESSION COOKIE (REQUIRED on Vercel) ===
# HMAC secret for the auth cookie issued by /api/session + /api/onboarding.
# Must be stable per deployment; rotating logs everyone out instantly.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# === NAMESTONE ===
NAMESTONE_API_KEY=

# === DEV WALLET (server-side scripts only — used by tsx scripts in /scripts) ===
# Private key (0x...) of the funded Sepolia dev wallet. NEVER expose client-side.
# Production user flow goes through Privy embedded wallets — this is the dev signing path only.
DEV_WALLET_PRIVATE_KEY=

# === x402 sender (server-side; usually client uses Privy Smart Wallet) ===
X402_SENDER_KEY=

# === x402 paywall — sample analyst sub-agent ===
# When X402_ANALYST_PAY_TO is set, /api/agents/analyst is paywalled via @x402/next.
# Unset = free (dev-friendly). Apify-style $1 USDC minimum.
X402_ANALYST_PAY_TO=
X402_ANALYST_PRICE=$1.00
X402_ANALYST_NETWORK=eip155:84532
NEXT_PUBLIC_ANALYST_ENS=analyst.ethtwin.eth

# === DEPLOYMENT ===
# Local dev only. On Vercel this is auto-derived from VERCEL_URL — leave unset there.
NEXT_PUBLIC_APP_URL=http://localhost:3000
